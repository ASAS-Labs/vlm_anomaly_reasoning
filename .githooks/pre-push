#!/usr/bin/env bash
# Pre-push gate: run ruff lint before allowing a push to remote.
# Uses `uvx` so it does not depend on the (heavy, GPU-specific) project venv.
set -euo pipefail

if ! command -v uvx >/dev/null 2>&1; then
  echo "pre-push: 'uvx' not found; install uv to lint before pushing: https://docs.astral.sh/uv/" >&2
  exit 1
fi

echo "pre-push: running ruff lint ..."
uvx ruff@0.15.17 check .
echo "pre-push: ruff passed."
